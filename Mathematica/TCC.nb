Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"dSC", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"V", "=", 
         RowBox[{"potentials", "[", 
          RowBox[{"[", "name", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"D", "[", 
          RowBox[{"V", ",", "\[Phi]"}], "]"}], "]"}], "/", "V"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"name", ",", 
       RowBox[{"Keys", "[", "potentials", "]"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TCC", "=", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"Assuming", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"c", "\[Element]", "Reals"}], ",", 
         RowBox[{"c1", "\[Element]", "Reals"}], ",", 
         RowBox[{"c2", "\[Element]", "Reals"}], ",", 
         RowBox[{"c3", "\[Element]", "Reals"}], ",", 
         RowBox[{"c4", "\[Element]", "Reals"}], ",", 
         RowBox[{"p", "\[Element]", "Reals"}], ",", 
         RowBox[{"p", ">=", "0"}]}], "}"}], ",", 
       RowBox[{"Limit", "[", 
        RowBox[{
         RowBox[{"dSC", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", 
         RowBox[{"\[Phi]", "->", "Infinity"}]}], "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"Length", "[", "dSC", "]"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"TableForm", "[", 
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Keys", "[", "potentials", "]"}], ",", "dSC", ",", "TCC"}], 
     "}"}], "]"}], ",", 
   RowBox[{"TableHeadings", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", 
      RowBox[{"{", 
       RowBox[{"\"\<Potential\>\"", ",", "\"\<|V'|/V\>\"", 
        ",", "\"\<\[Phi]->\[Infinity]\>\""}], "}"}]}], "}"}]}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.973766496457717*^9, 3.9737665492145452`*^9}, 
   3.973766589793655*^9, {3.973766642481481*^9, 3.973766712460487*^9}, 
