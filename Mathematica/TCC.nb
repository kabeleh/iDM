          RowBox[{"Sech", "[", 
           RowBox[{"c2", " ", "\[Phi]"}], "]"}], "2"]}], "]"}], 
       RowBox[{"c1", " ", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Tanh", "[", 
