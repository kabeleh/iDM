Notebook[{

Cell[CellGroupData[{
Cell["Trans-Planckian Censorship Conjecture", "Title",
 CellChangeTimes->{{3.973758806886436*^9, 3.973758817013193*^9}, {
  3.98342701007585*^9, 
  3.9834270212087927`*^9}},ExpressionUUID->"a7d88442-0652-456f-8418-\
6faf29af0775"],

Cell[TextData[{
 "The TCC avoids the classicalisation of quantum modes through expansion. \
What is quantum stays quantum. In 4, dimensions, this requires ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          RowBox[{
            FractionBox[
             TemplateBox[{
               RowBox[{
                 RowBox[{"\[Del]", 
                   StyleBox["V", "TI"]}]}]}, "Abs"], 
             StyleBox["V", "TI"]], "\[VerticalSeparator]"}], 
          RowBox[{"\[Phi]", "\[Rule]", "\[Infinity]"}]], "\[GreaterEqual]", 
         FractionBox["2", 
          SqrtBox[
           RowBox[{
             RowBox[{"(", 
               RowBox[{
                 StyleBox["d", "TI"], "-", "1"}], ")"}], "(", 
             RowBox[{
               StyleBox["d", "TI"], "-", "2"}], ")"}]]], "\[LongEqual]", 
         FractionBox["2", 
          SqrtBox["6"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\left.\\frac{\\left|\\nabla \
V\\right|}{V}\\right|_{\\phi\\rightarrow\\infty}\\geq\\frac{2}{\\sqrt{\\left(\
d-1\\right)\\left(d-2\\right)}}=\\frac{2}{\\sqrt{6}}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "443d944a-3429-4ed9-8201-99c7e27b351c"],
 "."
}], "Text",
 CellChangeTimes->{{3.973879097154064*^9, 3.9738791795813923`*^9}, {
  3.973879210165506*^9, 3.973879266881308*^9}, {3.9738793195998173`*^9, 
  3.9738795038911448`*^9}, {3.983427029508966*^9, 3.983427201611829*^9}, {
  3.983431608618511*^9, 
  3.983431621147822*^9}},ExpressionUUID->"14858ec1-8cbf-4150-bfb1-\
ec3cb3f19123"],

