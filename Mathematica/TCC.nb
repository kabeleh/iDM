Cell[TextData[{
 "The (inverse) power-law, the cosine, the pseudo-Nambu\[Dash]Goldstone, and \
the squared exponential violate the TCC.\nThe hyperbolic potentials requires ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["c", "TI"], "2"], "\[GreaterEqual]", "1", "/", 
         SqrtBox["6"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$c_2\\geq1/\\sqrt{6}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d5c59847-cf8d-4bb2-a87e-4e8b0ff1f142"],
 " to satisfy the TCC.\nThe exponential potential requires ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         SubscriptBox[
          StyleBox["c", "TI"], "2"], "|", "\[GreaterEqual]", "2", "/", 
         SqrtBox["6"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$|c_2|\\geq2/\\sqrt{6}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ef268a01-e61e-4e98-b790-f7607fe3cb5d"],
 " to satisfy the TCC.\nBean\[CloseCurlyQuote]s potential requires ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|", 
         SubscriptBox[
          StyleBox["c", "TI"], "3"], "|", "\[GreaterEqual]", "2", "/", 
         SqrtBox["6"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$|c_3|\\geq2/\\sqrt{6}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d092a186-4ed8-4b43-bd08-3fa8e52cd8ab"],
 " to satisfy the TCC.\nThe double exponential potential requires ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["c", "TI"], "2"], "\[GreaterEqual]", "2", "/", 
         SqrtBox["6"]}], TraditionalForm], "errors" -> {}, "input" -> 
