    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "391e4da4-28de-4815-8448-34b9fd5c5a04"],
 " to satisfy the TCC.\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["c", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "$c_1$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7650178d-ebff-4654-afd4-3186c916c801"],
 " is positive for all potentials."
