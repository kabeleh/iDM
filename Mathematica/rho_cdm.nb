bd7cfff1d09c"],

Cell[TextData[{
 "In the interacting dark matter model, the dark matter mass ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["m", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$m$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "80f00e46-0658-4db7-94b5-4c02cbf551c8"],
 " depends on the dark energy scalar field \[Phi], which is denoted as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$x$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3ddd7053-bd24-44e4-98f8-35d34cc9a464"],
 " in this notebook."
}], "Text",
 CellChangeTimes->{{3.971349281223899*^9, 
  3.9713493348645782`*^9}},ExpressionUUID->"4de99ec3-5360-4455-a042-\
48e5bda53f49"],

